# Base URL of the LLM endpoint (OpenAI-compatible Responses API).
# Example — Azure AI Foundry Agent:
#   https://<resource>.services.ai.azure.com/api/projects/<project>/applications/<agent>/protocols/openai
# A trailing "/responses" is also accepted — the provider strips and re-appends it.
LLM_ENDPOINT=

# API key sent to the LLM endpoint.
LLM_API_KEY=

# Header name used for auth. Use "api-key" for Azure Foundry/Azure OpenAI,
# leave blank to send "Authorization: Bearer <key>" (OpenAI default).
LLM_AUTH_HEADER=api-key

# Optional query parameter — e.g. "2025-11-15-preview" for Azure Foundry.
LLM_API_VERSION=

# Model identifier sent in the request body.
# For Azure Foundry agents: this must be the agent's UNDERLYING model (e.g. gpt-4.1-mini).
# The agent itself is selected via the /applications/<agent>/ path in LLM_ENDPOINT.
# For plain OpenAI/Azure OpenAI: the deployed model name (e.g. gpt-4o-mini).
NEXT_PUBLIC_LLM_MODEL_ID=
# Display name shown in the model selector UI — free text.
NEXT_PUBLIC_LLM_MODEL_NAME=Assistant

# Optional — separate model used for title generation. Falls back to NEXT_PUBLIC_LLM_MODEL_ID.
LLM_TITLE_MODEL_ID=
